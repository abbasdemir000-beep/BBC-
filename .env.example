# Copy this to .env.local and fill in your values

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET="km-secret-key-change-in-production-32chars"

# ── Anthropic / Claude AI ────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Firebase (optional — for image storage & social auth) ───────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Cloudflare (optional — for edge image storage) ───────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── Email (optional — for password reset emails) ─────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM="KnowledgeMarket <noreply@example.com>"
